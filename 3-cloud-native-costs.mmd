    subgraph Traps ["4. Fatal Architecture Cost Traps (Avoid)"]
        direction TB
        NAT["NAT Gateway Routing Fee (84 PB)<br/>+$3,780,000 / mo"]:::ghost
        S3Unbatched["Unbatched S3 PUTs (2.6T Requests)<br/>+$12,900,000 / mo"]:::ghost
        LogAll["Unsampled Telemetry / Logging<br/>Unlimited Hidden Cost"]:::ghost
        
        NAT --- S3Unbatched --- LogAll

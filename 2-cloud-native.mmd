graph TD
    %% ── Classes ─────────────────────────────────────────────
    classDef gold      fill:#1f1c15,stroke:#c8a96e,stroke-width:1.5px,color:#e8d5a8
    classDef sage      fill:#131a14,stroke:#7a9e7e,stroke-width:1px,color:#a8c8ac
    classDef steel     fill:#131620,stroke:#8896a8,stroke-width:1px,color:#b0bece
    classDef crimson   fill:#1a1212,stroke:#a87878,stroke-width:1px,color:#d4a0a0
    classDef ghost     fill:#111110,stroke:#2a2926,stroke-width:1px,color:#6a6860,stroke-dasharray:4 3
    classDef prominent fill:#c8a96e,stroke:#c8a96e,color:#1a1508,font-weight:600

    %% 1. Input Source
    Users(["Global Clients - 1M RPS / 32KB Payload"]):::prominent

    %% 2. Entry Point
    Users -->|Total 32 GB per sec| NLB["AWS Network Load Balancer L4"]:::steel

    %% Region Boundary
    subgraph Region["AWS REGION"]
        direction TB

        NLB -->|Distributes Traffic| AZ1
        NLB -->|Distributes Traffic| AZ2

        %% Availability Zone 1
        subgraph AZ1["Availability Zone A"]
            direction TB
            EKS_AZ1["Amazon EKS Pods Graviton"]:::steel
            MSK_AZ1["Amazon MSK Kafka Ingest"]:::sage
            Redis_AZ1["Amazon ElastiCache Redis Serve"]:::crimson
            
            EKS_AZ1 -->|Write to Commit Log| MSK_AZ1
            EKS_AZ1 -->|Read from Cache| Redis_AZ1
        end

        %% Availability Zone 2
        subgraph AZ2["Availability Zone B"]
            direction TB
            EKS_AZ2["Amazon EKS Pods Graviton"]:::steel
            MSK_AZ2["Amazon MSK Kafka Ingest"]:::sage
            Redis_AZ2["Amazon ElastiCache Redis Serve"]:::crimson
            
            EKS_AZ2 -->|Write to Commit Log| MSK_AZ2
            EKS_AZ2 -->|Read from Cache| Redis_AZ2
        end

        %% 3. Scaling Mechanics
        subgraph Scaling["Auto-Scaling Mechanism"]
            HPA["Kubernetes HPA Pods"]:::ghost
            CA["Cluster Autoscaler Nodes"]:::ghost
        end

        %% 4. Data Layer Synchronization
        subgraph SyncLayer["Data Replication"]
            MSK_AZ1 -.->|Cross AZ Data Transfer Cost| MSK_AZ2
            Redis_AZ1 -.->|Cross AZ Data Transfer Cost| Redis_AZ2
        end
    end

    %% Scaling Interactions
    Scaling -.->|Monitors and Scales| EKS_AZ1
    Scaling -.->|Monitors and Scales| EKS_AZ2

graph TD
%% ── Dark Elegant Theme ─────────────────────────────────
classDef gold      fill:#1f1c15,stroke:#c8a96e,stroke-width:1.5px,color:#e8d5a8
classDef sage      fill:#131a14,stroke:#7a9e7e,stroke-width:1px,color:#a8c8ac
classDef steel     fill:#131620,stroke:#8896a8,stroke-width:1px,color:#b0bece
classDef crimson   fill:#1a1212,stroke:#a87878,stroke-width:1px,color:#d4a0a0
classDef ghost     fill:#111110,stroke:#2a2926,stroke-width:1px,color:#6a6860,stroke-dasharray:4 3
classDef prominent fill:#c8a96e,stroke:#c8a96e,color:#1a1508,font-weight:600

    NLB["Network Load Balancer"]:::prominent

    subgraph Node ["Single VM Node Architecture"]
        RAM["RAM Buffer<br>(128GB)"]:::prominent
        ActiveDisk[("Active Network Disk<br>(Mem-Mapped WAL)")]:::gold
        FrozenDisk[("Frozen Network Disk<br>(Awaiting Offload)")]:::steel
    end

    subgraph Analytics ["Data & Analytics Tier"]
        ObjStore[("OCI Object Storage")]:::sage
        Trino["OCI Big Data Service<br>(Trino / Historical Query)"]:::gold
    end

    %% Ingest & Write
    NLB -- "[Step W1] Rx 1: Ingest Stream" --> RAM
    RAM -- "[Step W2] Tx 1: Write Append" --> ActiveDisk
    
    %% Egress (Live & Query Returns)
    RAM -- "[Step R1] Tx 2: Live Read Bypass<br>[Step R3] Tx 3: Query Return" --> NLB
    
    %% Frozen Disk Operations (Offload & Query Reads)
    FrozenDisk -- "[Step W3] Rx 3: Read to Offload<br>[Step R2] Rx 2: Query Read" --> RAM
    
    %% OCI Offload
    RAM -- "[Step W4] Tx 4: OCI Offload" --> ObjStore
    
    %% Historical Analytics (Bypasses Node)
    ObjStore -- "[Step R4] Historical Query" --> Trino
    
    class Node,Analytics ghost
